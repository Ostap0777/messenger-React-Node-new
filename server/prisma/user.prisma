model User {
  id        String @id @default(cuid())
  name      String
  email     String? @unique
  phone     String? @unique
  userTag   String @unique
  avatar    String?
  isOnline  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]
  chats     ChatUser[]
}